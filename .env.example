# 酒店预订系统 - 环境变量配置
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# Flask 安全密钥 (生产环境请使用随机字符串)
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-here

# 数据库连接 (可选，留空则使用 SQLite)
# MySQL 格式: mysql+pymysql://用户名:密码@主机:端口/数据库名
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/hotel_booking

# 调试模式 (生产环境设为 0)
FLASK_DEBUG=1

# 每页默认记录数
PER_PAGE=15
